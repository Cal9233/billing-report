# ---- Database ----
# SQLite (local development)
DATABASE_URL="file:./dev.db"

# MySQL (production) — uncomment and update for production:
# DATABASE_URL="mysql://user:password@localhost:3306/billflow"
# Also change prisma/schema.prisma provider from "sqlite" to "mysql"

# ---- NextAuth ----
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# ---- SMTP (optional - falls back to ethereal test account) ----
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM='"BillFlow" <noreply@billflow.local>'

# ---- Admin Notifications ----
ADMIN_NOTIFICATION_EMAIL="admin@example.com"

# ---- Seed defaults (used by prisma/seed.ts) ----
SEED_ORG_NAME="My Company"
SEED_ORG_SLUG="my-company"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# ---- E2E tests (used by Playwright test suite) ----
PLAYWRIGHT_BASE_URL="http://localhost:3000"
E2E_ADMIN_EMAIL="admin@example.com"
E2E_ADMIN_PASSWORD="ChangeMe123!"
